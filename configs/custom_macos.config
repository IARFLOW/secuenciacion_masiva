/*
 * Configuracion personalizada para macOS con 16 GB de RAM.
 * Limita los recursos para evitar que Docker consuma toda la memoria del sistema.
 *
 * Uso: nextflow run nf-core/bacass -r 2.5.0 -c configs/custom_macos.config ...
 */

process {
    resourceLimits = [
        cpus: 4,
        memory: '10.GB',
        time: '4.h'
    ]
}
